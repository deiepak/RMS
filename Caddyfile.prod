{
    auto_https disable_redirects
}

http://{$DOMAIN_NAME}, https://{$DOMAIN_NAME} {
    # Proxy API and Socket requests to the Node backend
    handle /api/* {
        reverse_proxy server:3001
    }
    handle /socket.io/* {
        reverse_proxy server:3001
    }
    handle /uploads/* {
        reverse_proxy server:3001
    }

    # Proxy all other requests to the compiled React frontend (Nginx container)
    handle {
        reverse_proxy client:80
    }
}
