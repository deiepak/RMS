# Database
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=your_root_password
DB_USER=rms_user
DB_PASSWORD=your_password
DB_NAME=rms_db

# Server
API_PORT=3001
JWT_SECRET=your_jwt_secret_change_this
NODE_ENV=development

# Default PINs (change in production)
ADMIN_PIN=1234
KITCHEN_PIN=5678
WAITER_PIN=9012

# CCTV Monitoring Configuration (Sintech / XMeye Pro)
CCTV_DVR_HOST=192.168.1.100
CCTV_DVR_HTTP_PORT=80
CCTV_DVR_MEDIA_PORT=34567
CCTV_DVR_RTSP_PORT=554
CCTV_DVR_USER=your_dvr_user
CCTV_DVR_PASS=your_dvr_password
CCTV_STREAM_MODE=development
